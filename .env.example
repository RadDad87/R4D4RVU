# Copy this file to ".env" and fill in your receiver's location.
# Find your lat/lon from a map; use decimal degrees (south/west are negative).

LAT=51.4700
LON=-0.4543

# Timezone (e.g. America/New_York, Europe/London)
TZ=Etc/UTC

# RTL-SDR tuner gain: "autogain" or a number like 49.6
GAIN=autogain

# Dongle serial or index. Leave as 0 if you only have one dongle.
RTLSDR_SERIAL=0
